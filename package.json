{
  "name": "dede",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web,bot -c blue,green,yellow \"npm run dev -w apps/api\" \"npm run dev -w apps/web\" \"npm run dev -w apps/bot\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:bot": "npm run dev -w apps/bot",
    "build": "npm run build -w packages/shared && npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "build:bot": "npm run build -w apps/bot",
    "start": "node apps/web/server.js",
    "lint": "eslint . --ext .ts,.tsx --ignore-path .gitignore",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "supabase db push",
    "generate:types": "supabase gen types typescript --linked > packages/shared/src/supabase-types.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
