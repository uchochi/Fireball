# ──────────────────────────────────────────────
# DEDE Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Get these from your Supabase project dashboard:
#   Settings → API → Project URL, anon key, service_role key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Server ────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── Telegram Bot ──────────────────────────────
# Get from https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
WEBAPP_URL=http://localhost:5173
# Set this to your deployed URL when using webhook mode (instead of polling)
WEBHOOK_URL=

# ── WhatsApp Cloud API (Meta) ─────────────────
# Requires Meta Business Account + WhatsApp Business Account
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=dede_webhook_verify

# ── Paystack ──────────────────────────────────
# https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenRouter (AI) ───────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model to use (any OpenRouter model ID). Recommended: openai/gpt-4o
OPENROUTER_MODEL=openai/gpt-4o

# ── Screenshot Service ────────────────────────
# Leave empty to use local Puppeteer.
# Set to an external endpoint if running screenshot rendering as a separate service.
SCREENSHOT_SERVICE_URL=
